generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  TASK_DUE
  TASK_CREATED
  TASK_UPDATED
  TASK_COMMENTED
  TASK_DELETED
  FILE_UPLOADED
  COMMENT_REACTED
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String           @id @default(uuid())
  name           String
  email          String           @unique
  emailVerified  DateTime?
  password       String?
  image          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now())
  firstName      String           @default("")
  lastName       String           @default("")
  accounts       Account[]
  Comment        Comment[]
  invitations    Invitation[]
  sessions       Session[]
  Subscription   Subscription[]
  Task           Task[]
  notifications  Notification[]
  notificationPreference NotificationPreference?
  pushSubscriptions PushSubscription[]
  teamMembers    TeamMember[]
  taskRecurrences TaskRecurrence[]
  commentReactions CommentReaction[]
}

model Team {
  id           String        @id @default(uuid())
  taskIndex    Int           @default(1)
  name         String
  slug         String        @unique
  domain       String?       @unique
  defaultRole  Role          @default(MEMBER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now())
  properties   Json          @default("{}")
  apiKeys      ApiKey[]
  invitations  Invitation[]
  subscription Subscription?
  tasks        Task[]
  members      TeamMember[]
  notifications Notification[]
  TeamCourse   TeamCourse[]
  Category     Category[]
  taskRecurrences TaskRecurrence[]
}

model Subscription {
  id              String             @id @default(uuid())
  teamId          String             @unique
  userEmail       String
  plan            Plan               @default(COMMUNITY)
  startDate       DateTime           @default(now())
  nextInvoiceDate DateTime?
  status          SubscriptionStatus @default(ACTIVE)
  isAnnual        Boolean            @default(false)
  payments        Payment[]
  team            Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userEmail], references: [email], onDelete: Cascade)
}

model Payment {
  id             String        @id @default(uuid())
  subscriptionId String
  date           DateTime
  amount         Int
  status         PaymentStatus
  paymentUrl     String?
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Task {
  id                       Int             @id @default(autoincrement())
  taskNumber               Int
  teamId                   String
  authorId                 String
  title                    String
  status                   String
  priority                 TaskPriority    @default(medium)
  kanbanOrder              Int             @default(0)
  duedate                  DateTime?       @db.Timestamptz
  description              String
  properties               Json
  recurrenceScheduleId     String?
  recurrenceOccurrenceDate DateTime?       @db.Timestamptz
  attachments              Attachment[]
  comments                 Comment[]
  author                   User            @relation(fields: [authorId], references: [id])
  team                     Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  recurrenceSchedule       TaskRecurrence? @relation(fields: [recurrenceScheduleId], references: [id], onDelete: SetNull)

  @@unique([recurrenceScheduleId, recurrenceOccurrenceDate])
  @@index([duedate])
  @@index([teamId, status, kanbanOrder])
  @@index([recurrenceScheduleId])
}

model TaskRecurrence {
  id                String               @id @default(uuid())
  teamId            String
  authorId          String
  title             String
  description       String
  taskStatus        String               @default("todo")
  priority          TaskPriority         @default(medium)
  unit              TaskRecurrenceUnit
  interval          Int                  @default(1)
  startAt           DateTime             @db.Timestamptz
  nextRunAt         DateTime             @db.Timestamptz
  timezone          String               @default("UTC")
  dueDateOffsetDays Int?
  status            TaskRecurrenceStatus @default(ACTIVE)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  author            User                 @relation(fields: [authorId], references: [id])
  team              Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks             Task[]

  @@index([teamId, status])
  @@index([status, nextRunAt])
}

model Comment {
  id          Int                @id @default(autoincrement())
  text        String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  taskId      Int
  createdById String
  createdBy   User               @relation(fields: [createdById], references: [id])
  task        Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reactions   CommentReaction[]
}

model CommentReaction {
  id        Int      @id @default(autoincrement())
  emoji     String
  commentId Int
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
}

model Attachment {
  id       String @id @default(uuid())
  taskId   Int
  filename String
  fileData Bytes
  url      String
  task     Task   @relation(fields: [taskId], references: [id])
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  title       String
  body        String
  link        String?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  metadata    Json?
  dedupeKey   String?          @unique

  recipientId String
  recipient   User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
  @@index([teamId])
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dhKey String
  authKey   String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      Role     @default(MEMBER)
  CourseProgress CourseProgress[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  
}

model Invitation {
  id        String   @id @default(uuid())
  teamId    String
  email     String
  role      Role     @default(MEMBER)
  token     String   @unique
  expires   DateTime
  invitedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  user      User     @relation(fields: [invitedBy], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
}

model Course {
  id             String            @id @default(uuid())
  name           String
  categoryId     String? // Relation to Category
  category       Category?         @relation(fields: [categoryId], references: [id])
  contentType    CourseContentType
  programContent String?
  description    String?
  url            String?
  estimatedTime  Int?
  thumbnail      String?
  questions      Json
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  teams          TeamCourse[] // Many-to-many relation with Team through TeamCourse
}

model TeamCourse {
  id        String   @id @default(uuid())
  teamId    String
  courseId  String
  progress  CourseProgress[] // Tracks user progress
  createdAt DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([teamId, courseId])
}

model CourseProgress {
  id           String      @id @default(uuid())
  teamCourseId String      
  teamMemberId String      
  progress     Int         // Could store progress as percentage or other measure (e.g., 0–100)
  answers      Json        
  updatedAt    DateTime    @updatedAt

  teamCourse   TeamCourse  @relation(fields: [teamCourseId], references: [id], onDelete: Cascade)
  teamMember   TeamMember  @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamCourseId, teamMemberId]) // Ensures progress is unique for each team member on a course
}

model Category {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false) // Indicates if it's a default category
  teamId    String? // Optional, if it's a team-specific category
  team      Team?    @relation(fields: [teamId], references: [id]) // Relation to Team
  courses   Course[] // Relation to Courses

  @@unique([name, teamId]) // Unique category name within a team
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  teamId     String
  hashedKey  String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  OWNER
  MEMBER
  AUDITOR
}

enum Plan {
  PREMIUM
  ULTIMATE
  COMMUNITY
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  DECLINED
}

enum PaymentStatus {
  SUCCESS
  FAILED
}

enum CourseContentType {
  EMBEDDED_VIDEO
  PRESENTATION_PDF
  OPEN_TEXT
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskRecurrenceUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

enum TaskRecurrenceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}
